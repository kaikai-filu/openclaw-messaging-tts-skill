# MiMo VoiceClone TTS — 环境变量配置
# 复制此文件为 .env 并填入真实值

# MiMo API Key（必填）
MIMO_API_KEY=your_mimo_api_key_here

# MiMo TTS API 端点（一般不用改）
MIMO_API_URL=https://token-plan-cn.xiaomimimo.com/v1/chat/completions

# 参考音频路径（用于语音克隆的样本）
REFERENCE_AUDIO=/path/to/reference-voice.mp3

# 输出音频格式（默认 mp3）
MIMO_TTS_FORMAT=mp3
